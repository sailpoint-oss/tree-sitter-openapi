{
  "name": "tree-sitter-openapi",
  "version": "0.1.0",
  "description": "OpenAPI grammar for tree-sitter (YAML and JSON)",
  "repository": "https://github.com/sailpoint-oss/tree-sitter-openapi",
  "license": "MIT",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "openapi",
    "yaml",
    "json"
  ],
  "files": [
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "tree-sitter.json",
    "tree-sitter-openapi/grammar.js",
    "tree-sitter-openapi/queries/*",
    "tree-sitter-openapi/src/**",
    "tree-sitter-openapi-json/grammar.js",
    "tree-sitter-openapi-json/queries/*",
    "tree-sitter-openapi-json/src/**"
  ],
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "tree-sitter": "^0.22.4",
    "tree-sitter-cli": "^0.25.4"
  },
  "peerDependencies": {
    "tree-sitter": "^0.22.4"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "build": "node scripts/build.js",
    "prestart": "npm run build && tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js"
  }
}
